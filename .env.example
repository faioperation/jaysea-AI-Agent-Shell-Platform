# =============================================================================
# .env.example - Jaysea AI-Agent Shell Platform
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# -------------------------------------------------------
# BACKEND - Application Settings
# -------------------------------------------------------
# Server port for the Express backend
PORT=8001

# Environment mode: development | production | test
NODE_ENV=production

# Backend public URL (used for generating avatar/file URLs)
# Example: https://api.yourdomain.com
BACKEND_URL=http://localhost

# Frontend URL (used in Google OAuth redirect + CORS)
# Example: https://yourdomain.com
FRONT_END_URL=http://localhost

# -------------------------------------------------------
# BACKEND - JWT Authentication
# -------------------------------------------------------
# Long random secret for signing access tokens
# Generate: openssl rand -hex 64
JWT_SECRET_TOKEN=your-very-long-super-secret-access-token-key-here

# Long random secret for signing refresh tokens (different from access)
# Generate: openssl rand -hex 64
JWT_REFRESH_TOKEN=your-very-long-super-secret-refresh-token-key-here

# Access token expiry (e.g., 15m, 1h, 1d)
JWT_EXPIRES_IN=15m

# Refresh token expiry (e.g., 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------------------
# BACKEND - Database (PostgreSQL)
# -------------------------------------------------------
# Full PostgreSQL connection URL used by Prisma ORM
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://jaysea:your_db_password@db:5432/jaysea_db?schema=public

# Database credentials (used by docker-compose to init the DB)
DB_USER=jaysea
DB_PASSWORD=your_db_password
DB_NAME=jaysea_db

# -------------------------------------------------------
# BACKEND - Redis Cache
# -------------------------------------------------------
# Redis connection URL (used for OTP storage + sessions)
# Format: redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://:your_redis_password@redis:6379

# Redis password (used by docker-compose redis command)
REDIS_PASSWORD=your_redis_password

# -------------------------------------------------------
# BACKEND - Email (SMTP / Nodemailer)
# -------------------------------------------------------
# SMTP host (e.g. smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP login username (usually your email)
SMTP_USER=your_email@gmail.com

# SMTP login password / App Password
# For Gmail: Generate at https://myaccount.google.com/apppasswords
SMTP_PASS=your_smtp_app_password

# From address displayed in emails
SMTP_FROM="Jaysea AI <noreply@jaysea.com>"

# -------------------------------------------------------
# BACKEND - Google OAuth2
# -------------------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Must match exactly what is registered in Google Cloud Console
# Format: https://yourdomain.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback

# -------------------------------------------------------
# AI SERVICE - OpenAI
# -------------------------------------------------------
# OpenAI API key - get from: https://platform.openai.com/api-keys
# Model used: gpt-4o-mini (configurable in openai_adapter.py)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# -------------------------------------------------------
# AI SERVICE - Pinecone Vector Database
# -------------------------------------------------------
# Pinecone API key - get from: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here

# Name of the Pinecone index for vector memory storage
# Will be auto-created if it doesn't exist
# Dimension: 1536 (required for text-embedding-3-small)
PINECONE_INDEX_NAME=ai-agent-memory

# -------------------------------------------------------
# FRONTEND - Next.js Public Variables
# -------------------------------------------------------
# Full URL to the backend API (must be publicly accessible from browser)
# In Docker production with Nginx: http://yourdomain.com/api
# In development: http://localhost:8001/api
NEXT_PUBLIC_API_URL=http://localhost/api

# -------------------------------------------------------
# AI SERVICE - Internal Routing
# -------------------------------------------------------
# Internal URL for AI service to call backend (Docker internal DNS)
# Do NOT expose this to the public
BACKEND_API_URL=http://backend:8001
