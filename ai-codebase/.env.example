# =============================================================================
# ai-codebase/.env.example
# =============================================================================

# OpenAI API Key - Required for LLM (gpt-4o-mini) and Embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-proj-your_openai_api_key

# Pinecone API Key - Required for Vector Memory (RAG)
PINECONE_API_KEY=your_pinecone_api_key

# Pinecone Index Name - Auto-created if not exists (dimension=1536, metric=cosine)
PINECONE_INDEX_NAME=ai-agent-memory

# Backend API URL - Used by AI service to fetch user profiles and experiences
BACKEND_API_URL=http://localhost:8001
